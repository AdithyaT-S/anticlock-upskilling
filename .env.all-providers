# ════════════════════════════════════════════════════════════════
# .env.local  ·  Docker Postgres (use this now)
# ════════════════════════════════════════════════════════════════
DB_PROVIDER=local
DB_USE_RLS=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freshcrm
NEXTAUTH_SECRET=local-dev-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
RESEND_API_KEY=re_local_placeholder
REDIS_URL=redis://localhost:6379


# ════════════════════════════════════════════════════════════════
# .env.supabase  ·  Supabase Cloud
# Get values from: supabase.com/dashboard → project → Settings → API
# ════════════════════════════════════════════════════════════════
# DB_PROVIDER=supabase
# DB_USE_RLS=true
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]
# SUPABASE_SERVICE_ROLE_KEY=[service-role-key]
# SUPABASE_JWT_SECRET=[jwt-secret]
# NEXT_PUBLIC_APP_URL=https://[domain].vercel.app
# RESEND_API_KEY=re_[key]
# RESEND_FROM_EMAIL=crm@[domain].com
# REDIS_URL=rediss://default:[pass]@[host].upstash.io:6380


# ════════════════════════════════════════════════════════════════
# .env.rds  ·  AWS RDS Postgres
# Get endpoint from: RDS console → your DB → Connectivity
# ════════════════════════════════════════════════════════════════
# DB_PROVIDER=rds
# DB_USE_RLS=true
# DATABASE_URL=postgresql://freshcrm:[password]@[endpoint].rds.amazonaws.com:5432/freshcrm?sslmode=require
# NEXTAUTH_SECRET=[openssl rand -base64 32]
# NEXTAUTH_URL=https://[domain].com
# NEXT_PUBLIC_APP_URL=https://[domain].com
# RESEND_API_KEY=re_[key]
# RESEND_FROM_EMAIL=crm@[domain].com
# REDIS_URL=redis://[elasticache-endpoint]:6379
# AWS_REGION=ap-south-1
# # Optional: use IAM auth instead of password
# RDS_IAM_AUTH=false


# ════════════════════════════════════════════════════════════════
# .env.neon  ·  Neon Serverless Postgres
# Get from: console.neon.tech → project → Connection details
# ════════════════════════════════════════════════════════════════
# DB_PROVIDER=neon
# DB_USE_RLS=true
# DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/freshcrm?sslmode=require
# NEXTAUTH_SECRET=[openssl rand -base64 32]
# NEXTAUTH_URL=https://[domain].vercel.app
# NEXT_PUBLIC_APP_URL=https://[domain].vercel.app
# RESEND_API_KEY=re_[key]
# REDIS_URL=rediss://default:[pass]@[host].upstash.io:6380


# ════════════════════════════════════════════════════════════════
# .env.railway  ·  Railway Postgres
# Railway injects DATABASE_URL and REDIS_URL automatically
# ════════════════════════════════════════════════════════════════
# DB_PROVIDER=railway
# DB_USE_RLS=true
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# NEXTAUTH_SECRET=[openssl rand -base64 32]
# NEXTAUTH_URL=https://[app].up.railway.app
# NEXT_PUBLIC_APP_URL=https://[app].up.railway.app
# RESEND_API_KEY=re_[key]
# REDIS_URL=${{Redis.REDIS_URL}}
